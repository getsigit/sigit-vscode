{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never",
        "group": "watch"
      },
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^\\s*(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[esbuild\\] watching for changes",
          "endsPattern": "\\[esbuild\\] (build complete|watching for changes)"
        }
      }
    }
  ]
}
